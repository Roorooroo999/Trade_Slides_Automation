# ── Posit Connect ─────────────────────────────────────────────────────
CONNECT_SERVER=https://your-posit-connect-url
CONNECT_API_KEY=your-posit-api-key-here

# ── AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── BigQuery ──────────────────────────────────────────────────────────
# Option A – service account JSON (Posit Connect)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B – ADC (local dev: run gcloud auth application-default login)
# No env var needed; ADC is picked up automatically.

# BQ project (default: wmt-execution-intel-prod)
# BQ_PROJECT_ID=wmt-execution-intel-prod
